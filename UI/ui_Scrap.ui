       <property name="styleSheet">
        <string notr="true">QTableWidget {
    background-color: #ffffff;
    alternate-background-color: #f8f9fa; 
    gridline-color: #dcdde1; /* Warna garis pembatas */
    border: 1px solid #dcdde1;
    border-radius: 10px;
    outline: none;
}

/* Memastikan garis vertikal dan horizontal terlihat */
QTableWidget::item {
    border-bottom: 1px solid #dcdde1;
    border-right: 1px solid #dcdde1;
}

/* Desain Header (Judul Kolom) */
QHeaderView::section {
    background-color: #FFD3DD; /* Hijau muda yang kamu pilih */
    color: #2C3E50;           /* Ganti ke Abu Tua/Gelap agar teks terbaca */
    padding: 10px;
    font-weight: bold;
    font-size: 13px;
    border: none;
    border-right: 1px solid #dcdde1; /* Garis vertikal di bagian header */
    border-bottom: 2px solid #dcdde1;
}

/* Hilangkan garis biru saat sel diklik */
QTableWidget::item:selected {
    background-color: #E0F2F1;
    color: #2C3E50;
}</string>
