        <property name="styleSheet">
         <string notr="true">QLabel {
    /* Gunakan font yang lebih ramping tapi tegas */
    font-family: &quot;Poppins&quot;, &quot;Montserrat&quot;, &quot;Segoe UI Semibold&quot;;
    font-size: 22px;
    font-weight: bold;
    color: #2c3e50; /* Sesuaikan dengan tema warnamu */
    
    /* Menambah jarak antar huruf agar tidak terlihat dempet/distorsi */
    letter-spacing: 3px; 
    
    /* Memberi ruang di bawah teks sebelum menyentuh garis/elemen lain */
    margin-bottom: 10px;
    padding-top: 5px;
}</string>
