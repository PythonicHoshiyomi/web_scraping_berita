          <string notr="true">/* Container Utama Kartu */
QFrame {
    background-color: #ffffff;
    border-radius: 12px;
    border: 1px solid #F8BBD0;
    padding: 10px;
}

/* 1. ROLE (Paling Atas) - Dibuat seperti pita/label kecil */
QLabel#label_role {
    color: #ffffff;
    background-color: #F48FB1; /* Pink Cerah */
    border-radius: 5px;
    padding: 2px 10px;
    font-size: 9px;
    font-weight: bold;
    text-transform: uppercase;
    border: none;
    max-width: 80px; /* Biar tidak kepanjangan */
}

/* 2. NAMA (Tengah) - Ukuran paling besar */
QLabel#label_nama {
    color: #AD1457; /* Pink Gelap */
    font-size: 15px;
    font-weight: bold;
    margin-top: 5px;
    background: transparent;
    border: none;
}

/* 3. NIM (Bawah) - Soft dan miring */
QLabel#label_nim {
    color: #7f8c8d;
    font-size: 11px;
    font-style: italic;
    background: transparent;
    border: none;
}</string>
