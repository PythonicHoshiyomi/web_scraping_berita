          <property name="styleSheet">
           <string notr="true">/* Gaya Standar */
QPushButton {
    background-color: #FFD3DD; /* Warna latar gelap */
    color: F0F9F8;               /* Warna teks */
    border-radius: 8px;         /* Membuat sudut melengkung */
    padding: 10px;
    font-size: 13px;
    text-align: justify;           /* Teks di tengah agar rapi di sidebar */
    padding-left: 15px;
    border: none;
}

/* Gaya saat kursor menyentuh tombol (Hover) */
QPushButton:hover {
    background-color: #4e6a85;  /* Warna sedikit lebih terang */
}

/* Gaya saat tombol diklik */
QPushButton:pressed {
    background-color: #2c3e50;  /* Warna lebih gelap */
}</string>
          </property>
